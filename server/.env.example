# ============================================
# SkyScope — Environment Variables
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your free API keys below
# 3. NEVER commit the real .env file to GitHub!

PORT=3000

# Get free key: https://www.n2yo.com/api/
N2YO_API_KEY=your_n2yo_api_key_here

# Get free credentials: https://astronomyapi.com/
ASTRONOMY_APP_ID=your_astronomy_app_id_here
ASTRONOMY_APP_SECRET=your_astronomy_app_secret_here

# Get free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here
